rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── members ──────────────────────────────────────────────────────
    // Holds name, group, isAdmin, and a bcrypt pinHash.
    // Only an admin can read this collection (needed to show the member
    // list with delete buttons in the Manage tab) — and even then the
    // pinHash field is never rendered or used by the client, since
    // verifying PINs always happens server-side in the login function.
    // All writes go through Cloud Functions (addMember/removeMember),
    // which run with elevated privileges — direct client writes are
    // blocked entirely so nobody can forge their own admin/group claim.
    match /members/{memberId} {
      allow read: if request.auth != null && request.auth.token.isAdmin == true;
      allow write: if false;
    }

    // ── config (current week) ───────────────────────────────────────
    // Anyone signed in can read it; only an admin (per their verified
    // custom-token claim) can change the current week.
    match /config/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.token.isAdmin == true;
    }

    // ── lists (Sunday visitor lists + visitors + comments) ──────────
    // Any signed-in team member can read all lists (needed for the "All
    // groups" view) and can update visitor status/comments on any list
    // (since a contact might be reassigned, and notes should be visible
    // team-wide). Only admins can create or delete whole lists, or
    // rewrite the full list shape (name, createdWeek, status).
    match /lists/{listId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.token.isAdmin == true;

      // Admin can do anything to a list, including delete.
      allow delete: if request.auth != null && request.auth.token.isAdmin == true;

      // Updates: admins can change anything. Non-admin members may only
      // touch the `visitors` array (status/comments), not the list's own
      // name/createdWeek/status fields.
      allow update: if request.auth != null && (
        request.auth.token.isAdmin == true ||
        (
          request.resource.data.name == resource.data.name &&
          request.resource.data.createdWeek == resource.data.createdWeek &&
          request.resource.data.status == resource.data.status
        )
      );
    }
  }
}
